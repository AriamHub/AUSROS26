
(define (problem example-1)
  (:domain cassini-MIR)
  (:objects
   htank ptanka ptankb - tank
   p1 p21 p22 p3 p4 p5 p6 p7 p8 p9 p10 p11 p12 p13 p14 p15 p16 p17 - point
   me1 me2 - engine
   lv1_21 lv1_22 lv3_4 lv3_5 lv5_6 lv5_7 lv10_14 lv11_15 lv12_16
   lv13_17 lv14_me1 lv15_me1 lv16_me2 lv17_me2 - latch
   pv21_3 pv22_3 pv4_5 pv5_6 pv5_7 pv8_10 pv9_11 pv8_12 pv9_13
   pv10_14 pv11_15 pv12_16 pv13_17 - pyro
   )
  (:init
   ;; tanks
   (exit_point htank p1)
   (contains htank he)
   (pressurised htank)

   (entry_point ptanka p6)
   (exit_point ptanka p8)
   (contains ptanka propa)

   (entry_point ptankb p7)
   (exit_point ptankb p9)
   (contains ptankb propb)

   ;; latch valves
   (entry_point lv1_21 p1)
   (exit_point lv1_21 p21)
   (entry_point lv1_22 p1)
   (exit_point lv1_22 p22)
   (entry_point lv3_4 p3)
   (exit_point lv3_4 p4)
   (entry_point lv3_5 p3)
   (exit_point lv3_5 p5)
   (entry_point lv5_6 p5)
   (exit_point lv5_6 p6)
   (entry_point lv5_7 p5)
   (exit_point lv5_7 p7)
   (entry_point lv10_14 p10)
   (exit_point lv10_14 p14)
   (entry_point lv11_15 p11)
   (exit_point lv11_15 p15)
   (entry_point lv12_16 p12)
   (exit_point lv12_16 p16)
   (entry_point lv13_17 p13)
   (exit_point lv13_17 p17)
   (entry_point lv14_me1 p14)
   (exit_point lv14_me1 me1)
   (entry_point lv15_me1 p15)
   (exit_point lv15_me1 me1)
   (entry_point lv16_me2 p16)
   (exit_point lv16_me2 me2)
   (entry_point lv17_me2 p17)
   (exit_point lv17_me2 me2)

   (operable lv1_21)
   (operable lv1_22)
   (operable lv3_4)
   (operable lv3_5)
   (operable lv5_6)
   (operable lv5_7)
   ;; (operable lv10_14) ; the frozen valve
   (operable lv11_15)
   (operable lv12_16)
   (operable lv13_17)
   (operable lv14_me1) ; what if it was this one?
   (operable lv15_me1)
   (operable lv16_me2)
   (operable lv17_me2)

   (open lv1_21)
   (closed lv1_22)
   (open lv3_4)
   (open lv3_5)
   (open lv5_6)
   (open lv5_7)
   (closed lv10_14)
   (closed lv11_15)
   (closed lv12_16)
   (closed lv13_17)
   (closed lv14_me1)
   (closed lv15_me1)
   (closed lv16_me2)
   (closed lv17_me2)
   
   ;; pyro valves
   (entry_point pv21_3 p21)
   (exit_point pv21_3 p3)
   (entry_point pv22_3 p22)
   (exit_point pv22_3 p3)
   (entry_point pv4_5 p4)
   (exit_point pv4_5 p5)
   (entry_point pv5_6 p5)
   (exit_point pv5_6 p6)
   (entry_point pv5_7 p5)
   (exit_point pv5_7 p7)
   (entry_point pv8_10 p8)
   (exit_point pv8_10 p10)
   (entry_point pv8_12 p8)
   (exit_point pv8_12 p12)
   (entry_point pv9_11 p9)
   (exit_point pv9_11 p11)
   (entry_point pv9_13 p9)
   (exit_point pv9_13 p13)
   (entry_point pv10_14 p10)
   (exit_point pv10_14 p14)
   (entry_point pv11_15 p11)
   (exit_point pv11_15 p15)
   (entry_point pv12_16 p12)
   (exit_point pv12_16 p16)
   (entry_point pv13_17 p13)
   (exit_point pv13_17 p17)

   (operable pv21_3)
   (operable pv22_3)
   (operable pv4_5)
   (operable pv5_6)
   (operable pv5_7)
   (operable pv8_10)
   (operable pv9_11)
   (operable pv8_12)
   (operable pv9_13)
   (operable pv10_14)
   (operable pv11_15)
   (operable pv12_16)
   (operable pv13_17)

   (open pv21_3)
   (closed pv22_3)
   (closed pv4_5)
   (closed pv5_6)
   (closed pv5_7)
   (open pv8_10)
   (open pv9_11)
   (closed pv8_12)
   (closed pv9_13)
   (closed pv10_14)
   (closed pv11_15)
   (closed pv12_16)
   (closed pv13_17)

   (= (total-cost) 0)
   )
  (:goal (and
	  ;; goal is to have generated thrust
	  (have-thrust)
	  ;; and then ensure both engines are off
	  (not (flow me1 propa))
	  (not (flow me1 propb))
	  (not (flow me2 propa))
	  (not (flow me2 propb))
	  ))
  (:metric minimize (total-cost))
  )

